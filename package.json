{
  "name": "doncor",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "cd frontend && npm install --legacy-peer-deps",
    "dev": "cd frontend && PORT=3000 HOST=0.0.0.0 npm start",
    "install:frontend": "cd frontend && npm install --legacy-peer-deps",
    "build": "cd frontend && npm run build",
    "start": "cd frontend && npm start",
    "test:backend": "pytest backend/tests -q",
    "test:frontend": "cd frontend && CI=true npm test -- --watch=false --runInBand",
    "test": "npm run test:backend && npm run test:frontend",
    "clean:frontend": "rm -rf frontend/node_modules frontend/package-lock.json",
    "reinstall:frontend": "npm run clean:frontend && npm run install:frontend",
    "build:frontend": "cd frontend && npm run build"
  },
  "engines": {
    "node": "20.x"
  }
}
