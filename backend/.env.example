# Doncor backend usando Supabase/Postgres
# Copie estas variáveis para a Railway em: Backend Service -> Variables

SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY_DO_SUPABASE

# Mantidas apenas por compatibilidade com o server.py atual.
# O adaptador Supabase ignora a URL do Mongo, mas o arquivo ainda lê essas variáveis na inicialização.
MONGO_URL=supabase
DB_NAME=doncor

# Opcional: URL pública usada pelo frontend na Vercel
# REACT_APP_BACKEND_URL=https://api.doncor.site
