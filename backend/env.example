# MongoDB Connection
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=doncor

# Supabase Configuration (optional)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET_BOLETOS=boletos

# Service Configuration
SERVICE_TYPE=main
PORT=8000

# RPA Service Configuration
RPA_SERVICE_URL=http://localhost:8001
RPA_TIMEOUT_SEGUNDOS=120

# Email Notifications (English or Portuguese names)
EMAIL_NOTIFICATIONS_ENABLED=false
# Alternative: NOTIFICAÇÕES_DE_EMAIL_ATIVADAS=falso
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Alternative: PORTA_SMTP=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
# Alternative: SENHA_SMTP=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
# Alternative: SMTP_DE_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=DonCor
CORRETOR_NOTIFICATION_EMAIL=your-email-where-chat-messages-should-arrive@gmail.com

