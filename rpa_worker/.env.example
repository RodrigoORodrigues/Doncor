# ──────────────────────────────────────────────────────────────────────────────
#  Doncor RPA Worker — Configuração
# ──────────────────────────────────────────────────────────────────────────────
#
#  1. Copie este arquivo para .env
#  2. Preencha os valores abaixo
#  3. Execute o script install_worker.bat para instalar as dependências
#  4. Rode:  python worker.py
#

# URL pública do seu backend no Railway (sem barra no final)
RAILWAY_API_URL=https://SEU-APP.up.railway.app

# Token de autenticação do worker
# IMPORTANTE: deve ser EXATAMENTE igual ao WORKER_TOKEN configurado no Railway
# Gere um token seguro com:  python -c "import secrets; print(secrets.token_hex(32))"
WORKER_TOKEN=COLE_AQUI_O_TOKEN_GERADO

# Supabase (para upload dos PDFs)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
SUPABASE_BUCKET_BOLETOS=boletos

# Intervalo de polling em segundos (padrão: 5)
POLL_INTERVAL_SECONDS=5

# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
